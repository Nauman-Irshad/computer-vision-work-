{
  "buildCommand": "npm run build",
  "installCommand": "npm install || true",
  "framework": null,
  "rewrites": [
    { "source": "/analyze", "destination": "/api/analyze" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "camera=(self)" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 10
    }
  }
}
